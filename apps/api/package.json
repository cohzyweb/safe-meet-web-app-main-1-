{
  "name": "@safe-meet/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "prisma generate",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx scripts/seed.ts",
    "demo:reset": "tsx scripts/reset-demo.ts",
    "demo:refresh": "pnpm run demo:reset && pnpm run db:seed"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^6.0.0",
    "@safe-meet/shared": "workspace:*",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "ioredis": "^5.6.1",
    "mjml": "^4.18.0",
    "nodemailer": "^8.0.4",
    "otplib": "^12.0.1",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.4",
    "viem": "^2.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/mjml": "^4.7.4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/web-push": "^3.6.4",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
